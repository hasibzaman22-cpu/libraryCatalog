MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=libraryCatalog
PORT=3000

# Required for sign-in sessions (use a long random string in production)
# On Vercel/serverless, sessions are stored in MongoDB (sessions collection), not in memory.
SESSION_SECRET=change-me-to-a-long-random-string
# Optional: absolute app URL for password reset links (otherwise inferred from incoming request)
# APP_BASE_URL=https://your-app.vercel.app

# Optional: Google sign-in — https://console.cloud.google.com/ → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID of type "Web application". ID and secret must be from the SAME client.
# "Invalid client secret" = copy the secret again from Console (or click Reset), paste into .env, restart server.
# Redirect URI in Google must match GOOGLE_CALLBACK_URL exactly (including port).
# GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-secret
# GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Set true when served over HTTPS
# COOKIE_SECURE=true

# Book recommendations — email (if contact contains @)
#
# Gmail: you cannot use your normal password. Turn on 2-Step Verification, then create an App password
# (Google Account → Security → App passwords). SMTP_USER = full address, SMTP_PASS = 16-char app password.
# Example discrete fields:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM="Your Name <you@gmail.com>"
#
# Option A: URL (encode special chars in password; spaces in app password often become %20)
# SMTP_URL=smtps://you@gmail.com:app-password@smtp.gmail.com:465
#
# Option B: discrete fields (same as Gmail block above for non-Gmail hosts)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Mawa'il <noreply@yourdomain.com>"

# Book recommendations — SMS (if contact is a phone number, no @)
# https://www.twilio.com/ — Console → Account Info: TWILIO_ACCOUNT_SID must start with AC…
# TWILIO_AUTH_TOKEN is the “Auth token” (not API Key secret). Error 20003 = wrong SID/token or extra spaces.
# Trial accounts can only text verified numbers. TWILIO_FROM_NUMBER must be a Twilio phone number you own.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+15551234567
